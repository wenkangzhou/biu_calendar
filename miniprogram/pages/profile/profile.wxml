<view class="page">
  <!-- 个人信息卡片 -->
  <view class="profile-card">
    <view class="profile-main" bindtap="onEditProfile">
      <view class="profile-avatar" style="background-color: {{myColor}};">
        <text wx:if="{{!user || !user.nick_name}}">👤</text>
        <text wx:elif="{{user.avatar_url}}">{{user.avatar_url}}</text>
        <text wx:else>{{user.nick_name[0]}}</text>
      </view>
      <view class="profile-info">
        <view class="profile-name">
          {{user && user.nick_name ? user.nick_name : '点击设置昵称'}}
          <text class="edit-icon">✏️</text>
        </view>
      </view>
    </view>
    <view class="profile-stats">
      <view class="stat-item">
        <view class="stat-num">{{stats.total}}</view>
        <view class="stat-label">总日程</view>
      </view>
      <view class="stat-item">
        <view class="stat-num">{{stats.today}}</view>
        <view class="stat-label">今日</view>
      </view>
      <view class="stat-item">
        <view class="stat-num">{{stats.todo}}</view>
        <view class="stat-label">待办</view>
      </view>
    </view>
  </view>

  <!-- 提示卡片 -->
  <view wx:if="{{!user || !user.nick_name}}" class="notice-card" bindtap="onEditProfile">
    <view class="notice-icon">ℹ️</view>
    <view class="notice-body">
      <view class="notice-title">请先设置你的昵称和头像</view>
      <view class="notice-desc" wx:if="{{!reviewMode}}">方便其他家庭成员识别你</view>
      <view class="notice-desc" wx:if="{{reviewMode}}">用于日历中展示</view>
    </view>
    <view class="notice-arrow">›</view>
  </view>

  <!-- 家庭卡片 -->
  <view class="section-card" wx:if="{{!reviewMode}}">
    <view wx:if="{{!hasFamily}}" class="empty-family">
      <view class="empty-icon">📅</view>
      <view class="empty-text">还没有加入家庭日历</view>
      <button class="btn-primary-small" bindtap="onGoFamily">创建或加入</button>
    </view>
    <view wx:else class="family-info" bindtap="onGoFamily">
      <view class="family-name">{{family.name}}</view>
      <view class="family-members">
      <view wx:for="{{family.members}}" wx:key="openid" class="fam-avatar" style="background-color: {{item.color}};">
        {{item.nickName[0]}}
      </view>
    </view>
      <view class="fam-arrow">›</view>
    </view>
  </view>

  <!-- 设置列表 -->
  <view class="settings-list">
    <view class="setting-item" bindtap="onSubscribe">
      <view class="setting-left">
        <text class="setting-title">日程提醒说明</text>
      </view>
      <view class="setting-right">
        <text class="setting-status">创建日程时授权</text>
        <text class="setting-arrow">›</text>
      </view>
    </view>
    <view class="setting-item" bindtap="onClearCache">
      <view class="setting-left">
        <view class="setting-icon icon-trash">🗑️</view>
        <text class="setting-title">清理缓存</text>
      </view>
      <view class="setting-right">
        <text class="setting-status">清理临时数据</text>
        <text class="setting-arrow">›</text>
      </view>
    </view>
  </view>
</view>
