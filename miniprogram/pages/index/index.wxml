<view class="page">
  <!-- 无家庭状态 -->
  <view wx:if="{{!hasFamily && !loading}}" class="empty-state">
    <view class="empty-title">欢迎使用家庭日历</view>
    <view class="empty-desc">创建或加入一个家庭，开始共享日程</view>
    <button class="btn-primary" bindtap="onGoFamily">去设置家庭</button>
  </view>

  <!-- 加载中 -->
  <view wx:elif="{{loading}}" class="loading-state">
    <view class="loading-text">加载中...</view>
  </view>

  <!-- 主界面 -->
  <block wx:else>
    <!-- 日历 -->
    <view class="calendar-card">
      <view class="calendar-header">
        <view class="month-nav">
          <view class="nav-btn" bindtap="onPrevMonth">‹</view>
          <view class="month-title">{{year}}年{{month}}月</view>
          <view class="nav-btn" bindtap="onNextMonth">›</view>
        </view>
        <view class="today-btn" bindtap="onGoToday">今天</view>
      </view>

      <view class="weekdays">
        <view wx:for="{{['日','一','二','三','四','五','六']}}" wx:key="*this" class="weekday {{index === 0 || index === 6 ? 'weekend' : ''}}">{{item}}</view>
      </view>

      <view class="days-grid">
        <view wx:for="{{calendarDays}}" wx:key="date"
          class="day-cell {{item.date === selectedDate ? 'selected' : ''}} {{item.date === today ? 'today' : ''}} {{item.day === 0 ? 'empty' : ''}}"
          bindtap="onSelectDate"
          data-date="{{item.date}}">
          <view class="day-content">
            <view class="day-num">{{item.day > 0 ? item.day : ''}}</view>
            <view wx:if="{{item.day > 0 && item.dots.length > 0}}" class="dots-row">
              <view wx:for="{{item.dots}}" wx:for-item="dot" wx:key="*this" class="day-dot" style="background-color: {{dot}};"></view>
            </view>
            <view wx:elif="{{item.day > 0 && item.lunarText}}" class="lunar-text {{item.lunarText.length > 2 ? 'small' : ''}}">{{item.lunarText}}</view>
            <view wx:else class="day-bar-placeholder"></view>
          </view>
        </view>
      </view>
    </view>

    <!-- 当日日程 -->
    <view class="daily-events">
      <view class="section-header">
        <view class="section-title">
          <text wx:if="{{selectedDate === today}}">今天 </text>
          <text>{{selectedDate}}</text>
          <text class="weekday-text"> {{weekdayText}}</text>
        </view>
      </view>

      <view wx:if="{{dailyEvents.length === 0}}" class="empty-day">
        <view class="empty-icon">📅</view>
        <view class="empty-title">这一天还没有安排</view>
        <view class="empty-desc">点击下方按钮添加日程</view>
      </view>

      <view wx:for="{{dailyEvents}}" wx:key="_id" class="event-item" bindtap="onEditEvent" data-id="{{item._id}}">
        <view class="event-avatar" style="background-color: {{item.creatorColor}};">{{item.creatorAvatarText}}</view>
        <view class="event-body">
          <view class="event-title">{{item.title}}</view>
          <view class="event-meta">
            <text wx:if="{{!item.is_all_day}}" class="event-time">{{formatTime(item.start_time)}} - {{formatTime(item.end_time)}}</text>
            <text wx:else class="event-time">全天</text>
            <view class="event-tags">
              <text class="tag-type {{item.type}}">{{item.type === 'family' ? '家庭' : '个人'}}</text>
              <text class="tag-creator" style="color: {{item.creatorColor}};">{{getMemberName(item.creator_openid)}}</text>
            </view>
          </view>
          <view wx:if="{{item.location}}" class="event-location">📍 {{item.location}}</view>
        </view>
      </view>
    </view>
  </block>

  <!-- 悬浮添加按钮 -->
  <view wx:if="{{hasFamily}}" class="fab" bindtap="onAddEvent">+</view>
</view>
